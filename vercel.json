{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/case-studies", "destination": "/results", "statusCode": 308 }
  ],
  "rewrites": [
    { "source": "/news", "destination": "/news/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/services", "destination": "/services/index.html" },
    { "source": "/results", "destination": "/results/index.html" },
    { "source": "/recent-work", "destination": "/recent-work/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
